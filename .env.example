# Supabase (Direktverbindung, Port 5432 – kein Pooler nötig für Hobby-Projekt)
DATABASE_URL="postgresql://postgres:DEIN_PASSWORT@db.DEINE_PROJEKT_ID.supabase.co:5432/postgres"

# Better-Auth Secret (mit `openssl rand -hex 32` generieren)
BETTER_AUTH_SECRET=DEIN_ZUFALLS_SECRET
# Better-Auth URL (angepasst an deine Domain)
BETTER_AUTH_URL=https://deine-domain.vercel.app
# Öffentliche Base URL
NEXT_PUBLIC_BASE_URL=https://deine-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://deine-domain.vercel.app
